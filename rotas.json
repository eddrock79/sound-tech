<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rotas — Banshee Sound Tech</title>

<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
  :root{
    --bg:#0d0d0f; --surface:#17171a; --surface2:#1f1f24; --border:#2a2a30;
    --accent:#e8b84b; --accent-dim:rgba(232,184,75,0.12);
    --blood:#e8b84b; --gold:#e8b84b;
    --text:#e8e8ec; --muted:#6b6b78; --line:#2a2a30; --panel:#17171a; --panel-2:#1f1f24;
  }
  *{box-sizing:border-box}
  html,body{margin:0}
  body{background:var(--bg); color:var(--text); font-family:'DM Sans',system-ui,sans-serif;
    font-size:15px; min-height:100vh; -webkit-font-smoothing:antialiased}
  .wrap{max-width:1500px;margin:0 auto;padding:18px 16px 60px}

  /* shared topbar + nav */
  .topbar{display:flex;align-items:center;justify-content:space-between;padding:0 20px;height:56px;
    background:var(--surface);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100;}
  .topbar-logo{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:2px;color:var(--accent);}
  .topbar-centre-logo{position:absolute;left:50%;transform:translateX(-50%);height:34px;width:auto;pointer-events:none;}
  .nav-bar{display:flex;gap:8px;background:var(--surface2);border-bottom:1px solid var(--border);
    padding:10px 16px;flex-wrap:wrap;}
  .nav-btn{padding:7px 14px;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;
    border:1px solid var(--border);background:var(--surface);color:var(--muted);text-decoration:none;
    display:inline-block;transition:color .2s,border-color .2s;-webkit-tap-highlight-color:transparent;}
  .nav-btn:hover{color:var(--text);border-color:var(--accent);}
  .nav-btn.current{background:var(--accent-dim);color:var(--accent);border-color:var(--accent);}

  .tabs{display:flex;gap:10px;margin:22px 0 14px}
  .tab{flex:1;cursor:pointer;border:1px solid var(--line);background:var(--panel);color:var(--muted);
    border-radius:12px;padding:14px 12px;text-align:center;font-family:'Bebas Neue';font-weight:500;
    letter-spacing:1.5px;text-transform:uppercase;transition:.18s;user-select:none}
  .tab small{display:block;font-family:'DM Sans';font-weight:400;letter-spacing:0;text-transform:none;
    font-size:12px;color:var(--muted);margin-top:5px}
  .tab:hover{border-color:#3a3344;color:var(--text)}
  .tab.active{color:#fff;border-color:var(--accent);background:var(--accent-dim)}
  .tab.active small{color:var(--accent)}

  .viewer{border:1px solid var(--line);border-radius:14px;background:var(--panel-2);
    min-height:50vh;position:relative;overflow:auto;padding:14px}

  /* the NAS-rendered rota block (cells carry their own inline colours) */
  table.rota{border-collapse:collapse;font-family:'DM Sans',Arial,sans-serif;font-size:13px;
    background:#fff;width:100%;border-radius:6px;overflow:hidden}
  table.rota td{border:1px solid #c8c8cc;padding:7px 10px;white-space:nowrap;min-width:40px}

  .state{position:absolute;inset:0;display:grid;place-items:center;text-align:center;padding:30px}
  .state .msg{font-family:'Bebas Neue';font-weight:300;letter-spacing:1px;color:var(--muted);font-size:15px}
  .spinner{width:34px;height:34px;border-radius:50%;margin:0 auto 14px;
    border:3px solid #2c2734;border-top-color:var(--accent);animation:spin 1s linear infinite}
  @keyframes spin{to{transform:rotate(360deg)}}

  .footer{display:flex;align-items:center;gap:12px;margin-top:14px;flex-wrap:wrap}
  .btn{cursor:pointer;border:1px solid var(--line);background:var(--panel);color:var(--text);
    border-radius:10px;padding:9px 14px;font-family:'Bebas Neue';font-weight:500;letter-spacing:1px;
    text-transform:uppercase;font-size:12px;transition:.18s;text-decoration:none}
  .btn:hover{border-color:var(--accent);color:#fff}
  .stamp{color:var(--muted);font-size:12px;margin-left:auto}
</style>
</head>
<body>

<div class="topbar" style="position:relative;">
  <div class="topbar-logo">📅 Rotas</div>
  <img class="topbar-centre-logo" src="../logo.jpg" alt="The Banshee Sound Tech">
  <div class="topbar-right"></div>
</div>
<div class="nav-bar">
  <a class="nav-btn" id="nav-home" href="../home">🏠 Home</a>
  <a class="nav-btn" href="../weekly-cleaning">📋 Weekly Jobs</a>
  <a class="nav-btn" href="../end-of-night">🌙 End Of Night</a>
  <span class="nav-btn current">📅 Rotas</span>
</div>

<div class="wrap">

  <div class="tabs">
    <div class="tab active" id="tab-this" onclick="show('this')">
      This Week<small id="lbl-this">—</small>
    </div>
    <div class="tab" id="tab-next" onclick="show('next')">
      Next Week<small id="lbl-next">—</small>
    </div>
  </div>

  <div class="viewer">
    <div id="sheet"></div>
    <div class="state" id="state">
      <div><div class="spinner"></div><div class="msg">Loading rotas…</div></div>
    </div>
  </div>

  <div class="footer">
    <button class="btn" onclick="load()">↻ Refresh</button>
    <span class="stamp" id="stamp"></span>
  </div>

</div>

<script>
  // The NAS publishes pre-rendered, colour-exact HTML blocks (cropped to just the
  // rota — no pay rates or cost data) plus a rotas.json manifest. We just fetch
  // and display them; nothing sensitive or heavy runs in the browser.
  const FILES = { this: 'this-week.html', next: 'next-week.html' };
  let manifest = null;
  let current = 'this';
  const bust = () => '?t=' + Date.now();

  function setState(html){
    const s = document.getElementById('state');
    if (html === null){ s.style.display = 'none'; return; }
    s.style.display = 'grid';
    s.innerHTML = '<div><div class="msg">' + html + '</div></div>';
  }

  async function show(which){
    current = which;
    document.getElementById('tab-this').classList.toggle('active', which==='this');
    document.getElementById('tab-next').classList.toggle('active', which==='next');
    document.getElementById('sheet').innerHTML = '';

    const meta = manifest && manifest[which==='this' ? 'thisWeek' : 'nextWeek'];
    if (!meta){ setState('No rota published for this week yet.'); return; }

    setState('<div class="spinner"></div>Loading rota…');
    try{
      const res = await fetch(FILES[which] + bust());
      if (!res.ok) throw new Error('not found');
      document.getElementById('sheet').innerHTML = await res.text();
      setState(null);
    }catch(err){
      setState('Could not load this rota.<br><small style="color:#7d7689">' + String(err) + '</small>');
    }
  }

  async function load(){
    setState('<div class="spinner"></div>Loading rotas…');
    try{
      const res = await fetch('rotas.json' + bust());
      manifest = await res.json();
    }catch(e){ manifest = null; }
    document.getElementById('lbl-this').textContent =
      manifest && manifest.thisWeek ? ('w/e ' + manifest.thisWeek.label) : 'none';
    document.getElementById('lbl-next').textContent =
      manifest && manifest.nextWeek ? ('w/e ' + manifest.nextWeek.label) : 'none';
    if (manifest && manifest.generated){
      document.getElementById('stamp').textContent =
        'Updated ' + new Date(manifest.generated).toLocaleString('en-GB');
    }
    show(current);
  }

  load();
</script>
</body>
</html>
